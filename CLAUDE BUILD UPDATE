// ── LEAGUE SIM ENGINE ────────────────────────────────────────────────────────
// Simulates all CPU vs CPU matchups for the week using team OVR strength.
// Uses NFL-accurate win probability: better team wins more but upsets happen.
function simLeagueWeek(leagueRecords, week, userWon) {
const cpuTeams = VFL_ALL_TEAMS.filter(t=>t.city&&t.id.match(/^t\d+$/)&&parseInt(t.id.slice(1))<=30);
const records = { …(leagueRecords||{}) };

// Initialize any missing team records
cpuTeams.forEach(t => {
if (!records[t.id]) records[t.id] = { w:0, l:0, pf:0, pa:0 };
});
// User team
if (!records[“user”]) records[“user”] = { w:0, l:0, pf:0, pa:0 };
if (userWon) records[“user”].w++; else records[“user”].l++;

// Pair up CPU teams into 16 games (32 teams / 2)
const shuffled = […cpuTeams].sort((a,b)=>(nameHash(a.id+week))-(nameHash(b.id+week)));
for (let i=0; i<shuffled.length-1; i+=2) {
const home = shuffled[i];
const away = shuffled[i+1];
// Team strength from seeded overall average
const homeSeed = home.id.split(’’).reduce((a,c)=>a+c.charCodeAt(0),0);
const awaySeed = away.id.split(’’).reduce((a,c)=>a+c.charCodeAt(0),0);
const homeOvr = 68 + (homeSeed % 28); // 68–95 range, deterministic per team
const awayOvr = 68 + (awaySeed % 28);
// NFL-style win prob: talent gap matters but upsets happen ~30% of time
const gap = (homeOvr - awayOvr) / 40; // normalize
const homeWinProb = Math.min(0.80, Math.max(0.20, 0.52 + gap));
const homeWins = Math.random() < homeWinProb;
// Realistic score generation
const winScore  = 17 + Math.round(Math.random() * 21);
const lossScore = Math.round(Math.random() * (winScore - 3));
records[home.id].pf += homeWins ? winScore : lossScore;
records[home.id].pa += homeWins ? lossScore : winScore;
records[away.id].pf += homeWins ? lossScore : winScore;
records[away.id].pa += homeWins ? winScore : lossScore;
if (homeWins) { records[home.id].w++; records[away.id].l++; }
else          { records[away.id].w++; records[home.id].l++; }
}
return records;
}

