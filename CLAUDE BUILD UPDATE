// CPU team roster generation (seeded by team id for consistency)
function filterRosterByGroup(roster, group) {
if (!Array.isArray(roster)) return [];
const map = {
QB:[“QB”], RB:[“RB”], WR:[“WR”], TE:[“TE”],
OL:[“LT”,“LG”,“C”,“RG”,“RT”],
DL:[“LE”,“RE”,“DT”],
LB:[“LOLB”,“MLB”,“ROLB”],
CB:[“CB”], S:[“S”], KP:[“K”,“P”],
};
if (!map[group]) return roster;
return roster.filter(p => p && map[group].includes(p.position));
}

function generateCpuRoster(teamId) {
const seed = teamId.split(’’).reduce((a,c)=>a+c.charCodeAt(0),0);
const rng = (min,max) => min+Math.abs(Math.sin(seed*(min+max+1))*1000)%(max-min+1)|0;
const roster = [];
