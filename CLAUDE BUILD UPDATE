function handleSave() {
if (isUserTeam) {
// Only save kits + identity back to franchise for user team
const featuredKit = kits[featured];
if (onThemeChange) onThemeChange(featuredKit.jerseyColor, featuredKit.jerseyAccentColor, kits, featured, kitNumbers);
if (onUpdateFranchise) {
onUpdateFranchise({
…franchise,
city: editCity, teamName: editTeamName,
name: `${editCity} ${editTeamName}`,
primaryColor: editPrimary, secondaryColor: editSecondary,
kits, featured, kitNumbers,
themeKit:{ primary:featuredKit.jerseyColor, secondary:featuredKit.jerseyAccentColor }
});
}
} else {
// Save other team’s kits to state AND localStorage — never touches user franchise
const updated = {
…teamColorOverrides,
[editingTeam]: {
city: baseTeamMeta.city,
name: baseTeamMeta.name,
…teamColorOverrides[editingTeam],
kits, kitNumbers,
primary:   currentTeamMeta.primary,
secondary: currentTeamMeta.secondary,
