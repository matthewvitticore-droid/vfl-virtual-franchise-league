function darkenHex(hex, amt) {
try {
const n=parseInt(hex.replace(”#”,””),16);
const r=Math.max(0,((n>>16)&0xff)-amt);
const g=Math.max(0,((n>>8)&0xff)-amt);
const b=Math.max(0,(n&0xff)-amt);
return `rgb(${r},${g},${b})`;
} catch { return hex; }
}

