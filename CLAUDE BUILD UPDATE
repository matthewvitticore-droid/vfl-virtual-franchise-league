let [min, max] = ranges[pos] || ranges[group] || [60, 90];
// Outlier check — rare elite speed
const eligiblePos = [“WR”,“CB”,“RB”,“FS”].includes(pos);
const hasSpeedTrait = player.traits?.includes(“Speedster”) || player.archetypeTrait===“Speedster”;
const eliteDev  = [“Superstar”,“X-Factor”].includes(player.devTrait);
const eliteForty= player.combine?.forty != null && player.combine.forty <= 4.35;
if (eligiblePos && (hasSpeedTrait || eliteDev || eliteForty)) {
max = 99;
}
attrs.SPD = Math.max(min, Math.min(max, attrs.SPD));
// Rarity gate — deterministic ~15% keep 98–99
if (attrs.SPD >= 98) {
const seed = (player.overall || 60) * 7 + (player.age || 25) * 3;
if (seed % 100 > 15) attrs.SPD = 97;
}
return { …player, attributes: attrs };
}
