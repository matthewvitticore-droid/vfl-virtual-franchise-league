const tfl = Math.round(g * (0.5 + q*0.7 + ((s*3)%4)/10));
return { G:g, TCK:tck, SCK:parseFloat(sck), INT:int, TFL:tfl, PD:Math.round(g*(0.2+q*0.4)) };
}
if (pos===“CB”) {
const tck = Math.round(g * (2.5 + q*1.5 + (s%4)));
const int = Math.round(g * (0.1 + q*0.35 + ((s*7)%4)/10));
const pbu = Math.round(g * (0.5 + q*1 + ((s*3)%5)/10));
return { G:g, TCK:tck, INT:int, PBU:pbu, TD:Math.round(int*0.2) };
}
if (pos===“S”) {
const tck = Math.round(g * (4 + q*2.5 + (s%5)));
const int = Math.round(g * (0.1 + q*0.25 + ((s*5)%3)/10));
const pbu = Math.round(g * (0.3 + q*0.7 + ((s*7)%4)/10));
return { G:g, TCK:tck, INT:int, PBU:pbu, FF:Math.round(g*0.08*(s%3)) };
}
if (pos===“K”) {
const fga = Math.round(g * (1.5 + (s%2)));
const fgm = Math.round(fga * (0.78 + q*0.15));
const xpa = Math.round(g * 2.2);
return { G:g, FGM:fgm, FGA:fga, [`FG%`]:`${Math.round(fgm/Math.max(1,fga)*100)}%`, XPM:Math.round(xpa*0.96), LNG:`${45+(s%25)}yd` };
}
if (pos===“P”) {
const punts = Math.round(g * (3 + (s%3)));
const avg = (43 + q*6 + ((s*3)%5)).toFixed(1);
return { G:g, PUNTS:punts, AVG:avg, NET:(parseFloat(avg)-6.5).toFixed(1), TB:Math.round(punts*0.1), [`IN20`]:Math.round(punts*0.35) };
}
// OL — no traditional stats
return { G:g, GS:Math.round(g*(0.6+q*0.4)), [`PEN`]:Math.round(g*0.3*(s%4)) };
}

function combineToRating(val, curve) {
for(let i=0;i<curve.length-1;i++){
const [v1,r1]=curve[i], [v2,r2]=curve[i+1];
if(val<=v1&&val>=v2){
const t=(val-v1)/(v2-v1);
return Math.round(r1+t*(r2-r1));
}
}
return val<=curve[0][0]?curve[0][1]:curve[curve.length-1][1];
}

