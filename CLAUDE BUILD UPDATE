// ─── GLOBAL DRAFT BOARD ───────────────────────────────────────────────────────
// ONE source of truth for the entire draft.
// 224 picks in order. currentOwnerTeamId = who picks there.
// Trades only update currentOwnerTeamId. Nothing else.
function generateGlobalDraftBoard(season, userTeamId, wins, losses, draftAssets, leagueRecords) {
const USER_ID = userTeamId||“user”;

// User’s base slot from real league standings (worst record = pick 1, NFL rules)
let userBaseSlot;
if (leagueRecords && Object.keys(leagueRecords).length > 0) {
const order = getDraftOrder(leagueRecords, franchise?.lastChampionId||null);
const userIdx = order.findIndex(t=>t.id===“user”);
userBaseSlot = userIdx >= 0 ? userIdx + 1 : Math.max(1, Math.min(32, Math.round(33 - (wins/Math.max(1,wins+losses))*32)));
} else {
const totalGames = Math.max(1, wins+losses);
const winPct = wins/totalGames;
userBaseSlot = Math.max(1, Math.min(32, Math.round(33 - winPct*32)));
}

// Collect user’s assets for this season, map round→[assets]
const userAssets = (draftAssets||[]).filter(a=>a.year===season&&!a.isUsed);
const assetsByRound = {};
userAssets.forEach(a=>{
if(!assetsByRound[a.round]) assetsByRound[a.round]=[];
assetsByRound[a.round].push(a);
});

// For each round, determine which slot# the user picks at
// Base pick: slot = userBaseSlot
// Extra picks (from trades): spread around userBaseSlot with earlier slots
const userSlots = {}; // pickNumber (1-224) -> assetId
for(let round=1;round<=7;round++){
const roundAssets=(assetsByRound[round]||[]).sort((a,b)=>{
// Sort by overallPick if set, else by when they were acquired
if(a.overallPick&&b.overallPick) return a.overallPick-b.overallPick;
if(a.overallPick) return -1;
if(b.overallPick) return 1;
return 0;
});
const usedSlots=new Set();
roundAssets.forEach((asset,i)=>{
let slot;
if(asset.overallPick){
// Pick has an assigned slot from trade
slot=((asset.overallPick-1)%32)+1;
} else if(i===0){
slot=userBaseSlot;
} else {
// Extra pick: place earlier than base (traded for usually means better)
slot=Math.max(1, userBaseSlot - i*4);
while(usedSlots.has(slot)&&slot>1) slot–;
while(usedSlots.has(slot)&&slot<32) slot++;
}
slot=Math.max(1,Math.min(32,slot));
while(usedSlots.has(slot)&&slot<32) slot++;
usedSlots.add(slot);
const pickNumber=(round-1)*32+slot;
userSlots[pickNumber]=asset.id;
});
}

// Build the 224-pick board
const board=[];
for(let round=1;round<=7;round++){
for(let slot=1;slot<=32;slot++){
const pickNumber=(round-1)*32+slot;
const isUser=!!userSlots[pickNumber];
const cpuTeamIdx=slot-1; // 0-31, maps to VFL_DRAFT_TEAMS
board.push({
pickId:   `${season}-R${round}-${String(pickNumber).padStart(3,"0")}`,
pickNumber,
round,
slot,
originalOwnerTeamId: isUser ? USER_ID : `cpu_${cpuTeamIdx}`,
currentOwnerTeamId:  isUser ? USER_ID : `cpu_${cpuTeamIdx}`,
playerSelectedId:    null,
assetId:             userSlots[pickNumber]||null,
});
}
}
return board;
}

