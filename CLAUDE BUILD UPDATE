const VFL_ALL_DIV_TEAMS = Object.values(VFL_DIVISIONS).flatMap(conf=>Object.values(conf).flat());
const CONF_COLOR = {EAST:”#C0392B”, WEST:”#2471A3”};
const DIV_LABELS = {NE:“Northeast”,NW:“Northwest”,SE:“Southeast”,SW:“Southwest”};

// Sort teams in a division by record
function sortDiv(teams, records) {
return […teams].sort((a,b)=>{
const ra=records[a.id]||{w:0,l:17,pf:0,pa:0};
const rb=records[b.id]||{w:0,l:17,pf:0,pa:0};
const pa=ra.w/Math.max(1,ra.w+ra.l), pb=rb.w/Math.max(1,rb.w+rb.l);
if(Math.abs(pa-pb)>0.001) return pb-pa;
return (rb.pf-rb.pa)-(ra.pf-ra.pa);
});
}

// Get 7 playoff seeds per conference: 4 div winners + 3 wild cards
function getConfSeeds(conf, records) {
const divs = VFL_DIVISIONS[conf];
const winners = Object.values(divs).map(t=>sortDiv(t,records)[0])
.sort((a,b)=>{
const ra=records[a.id]||{w:0,l:17}, rb=records[b.id]||{w:0,l:17};
return (rb.w/(rb.w+rb.l))-(ra.w/(ra.w+ra.l));
});
const winIds = new Set(winners.map(t=>t.id));
const wcs = Object.values(divs).flat()
.filter(t=>!winIds.has(t.id))
.sort((a,b)=>{
const ra=records[a.id]||{w:0,l:17}, rb=records[b.id]||{w:0,l:17};
return (rb.w/(rb.w+rb.l))-(ra.w/(ra.w+ra.l));
});
return […winners, …wcs.slice(0,3)];
}

// Draft order: worst overall record picks first. Champion picks last (#32).
// Uses cross-conference overall record, not just conference.
function getDraftOrder(leagueRecords, championId=null) {
const allIds = new Set([
“user”,
…VFL_ALL_DIV_TEAMS.map(t=>t.id)
]);
const teams = […allIds]
.filter(id => leagueRecords[id])
.map(id => {
const r = leagueRecords[id]||{w:0,l:0,pf:0,pa:0};
return {id, w:r.w||0, l:r.l||0, pf:r.pf||0, pa:r.pa||0,
pct:(r.w||0)/Math.max(1,(r.w||0)+(r.l||0))};
});
// Sort worst→best; champion forced to slot 32
const nonChamp = teams.filter(t=>t.id!==championId).sort((a,b)=>{
if(Math.abs(a.pct-b.pct)>0.001) return a.pct-b.pct;
return (a.pf-a.pa)-(b.pf-b.pa);
});
const champ = teams.find(t=>t.id===championId);
return champ ? […nonChamp, champ] : nonChamp;
}

