// Derive visible scouting trait from combine + position
function deriveVisibleTrait(pos, combine, overall) {
const forty = parseFloat(combine.fortyYard);
const bench = combine.bench;
const cone  = parseFloat(combine.threeCone||7.0);
if (pos===“QB”) return forty<=4.65?“Dual Threat”:overall>=85?“Field General”:overall>=75?“Gunslinger”:“Game Manager”;
if (pos===“RB”) return forty<=4.40?“Speed Back”:bench>=28?“Power Back”:cone<=6.70?“Elusive Back”:“Balanced Back”;
if (pos===“WR”) return forty<=4.40?“Deep Threat”:cone<=6.70?“Route Runner”:forty>=4.55?“Possession WR”:“Raw Athlete”;
if (pos===“TE”) return forty<=4.60?“Move TE”:bench>=30?“Blocking TE”:overall>=80?“Receiving TE”:“H-Back”;
if ([“LT”,“LG”,“C”,“RG”,“RT”].includes(pos)) return bench>=35?“Mauler”:cone<=6.90?“Pass Protector”:bench>=28?“Run Blocker”:“Technician”;
if ([“LE”,“RE”].includes(pos)) return forty<=4.65?“Speed Rusher”:bench>=30?“Power Rusher”:“Complete DE”;
if (pos===“DT”) return bench>=36?“Run Stuffer”:cone<=6.80?“Penetrator”:“Complete DE”;
if ([“LOLB”,“ROLB”].includes(pos)) return forty<=4.65?“Pass Rusher”:“Coverage LB”;
if (pos===“MLB”) return bench>=28?“Run Stopper”:forty<=4.68?“Coverage MLB”:“Run Stopper”;
if (pos===“CB”) return forty<=4.40?“Press Corner”:cone<=6.65?“Slot Corner”:bench>=15?“Lockdown”:“Zone Hawk”;
if (pos===“S”) return forty<=4.48?“Free Safety”:bench>=26?“Box Safety”:cone<=6.80?“Coverage Safety”:“Strong Safety”;
return “Athlete”;
}

