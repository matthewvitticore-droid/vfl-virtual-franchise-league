function DepthChartTab({ franchise, onUpdate }) {
const depthOrder = franchise.depthOrder||{};

function getOrdered(pos) {
const roster = franchise.roster.filter(p=>p.position===pos);
const order = depthOrder[pos];
if(!order) return […roster].sort((a,b)=>b.overall-a.overall);
return order.map(id=>roster.find(p=>p.id===id)).filter(Boolean)
.concat(roster.filter(p=>!order.includes(p.id)));
}

function move(pos, idx, dir) {
const ordered = getOrdered(pos).map(p=>p.id);
const target = idx+dir;
if(target<0||target>=ordered.length) return;
[ordered[idx],ordered[target]]=[ordered[target],ordered[idx]];
onUpdate({…franchise, depthOrder:{…depthOrder,[pos]:ordered}});
}

return (
