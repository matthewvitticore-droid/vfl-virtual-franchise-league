function buildDraftOrder(userPickSlot) {
const order = [];
for(let round=1;round<=7;round++) {
for(let slot=1;slot<=32;slot++) {
const overallPick = (round-1)*32+slot;
const isUser = slot===userPickSlot;
order.push({round,slot,overallPick,teamIdx:slot-1,isUser});
}
}
return order;
}

