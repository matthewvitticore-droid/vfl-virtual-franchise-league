function fillMissingRatings(player) {
if (!player) return player;
const required = POSITION_ATTRIBUTES[player.position] || [];
if (!required.length) return player;
const attrs = { …(player.attributes || {}) };

// Check if ALL required attributes already exist — if so, return as-is
const allPresent = required.every(key => attrs[key] != null);
if (allPresent) return player;

// Only fill genuinely missing attributes
const base = player.overall || 70;
const dev = player.devTrait || “Starter”;
const lo = dev===“Superstar”||dev===“Star” ? base-8  : dev===“Backup” ? base-18 : base-12;
const hi = dev===“Superstar”||dev===“Star” ? Math.min(99,base+5) : dev===“Backup” ? base-2  : base+3;

required.forEach((key, i) => {
if (attrs[key] != null) return; // NEVER touch existing values
const offset = ((base * 7 + i * 13) % 11) - 5;
attrs[key] = Math.max(40, Math.min(99, Math.round(Math.max(lo, Math.min(hi, base + offset)))));
});

return { …player, attributes: attrs };
}
function applyCombineAndTraits(player) {
