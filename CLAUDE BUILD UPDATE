export default function App() {
const [screen,setScreen]=useState(“home”);
const [franchise,setFranchise]=useState(null);
const saved=!!localStorage.getItem(“vfl_franchise”);

useEffect(()=>{
if (window.supabase) return;
const s = document.createElement(“script”);
s.src = “https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2”;
s.onload = () => console.log(“Supabase ready”);
document.head.appendChild(s);
},[]);

function saveFranchise(f){setFranchise(f);try{localStorage.setItem(“vfl_franchise”,JSON.stringify(f));}catch(e){}}
function loadFranchise(){
try{
const f=JSON.parse(localStorage.getItem(“vfl_franchise”));
if(f){
// Recalculate attributes for all saved players to fix any pre-fix bad ratings
const fixRoster = (roster) => (roster||[]).map(p=>fillMissingRatings(p));
const fixed={
…f,
roster:fixRoster(f.roster),
practiceSquad:fixRoster(f.practiceSquad),
freeAgents:fixRoster(f.freeAgents),
};
setFranchise(fixed);
setScreen(“hub”);
}
}catch(e){}
}

function hardReset() {
// Clear all VFL data including any scoped team kit keys
Object.keys(localStorage).filter(k=>k.startsWith(“vfl_”)).forEach(k=>localStorage.removeItem(k));
setFranchise(null);
setScreen(“home”);
}

if(screen===“home”) return <HomeScreen onNew={()=>setScreen(“create”)} onLoad={loadFranchise} hasSaved={saved} onReset={hardReset}/>;
if(screen===“create”) return <CreateScreen onBack={()=>setScreen(“home”)} onCreated={f=>{
saveFranchise(f);
setScreen(“hub”);
}}/>;
if(screen===“hub”&&franchise) return <FranchiseHub franchise={franchise} onUpdate={saveFranchise} onBack={()=>setScreen(“home”)}/>;
return null;
}
