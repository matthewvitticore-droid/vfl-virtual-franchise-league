// ─── PLAYOFF BRACKET ──────────────────────────────────────────────────────────
function PlayoffBracket({ franchise, onUpdate }) {
const pc = franchise.primaryColor;
const sc = franchise.secondaryColor;
const [result, setResult] = useState(null);
const round = franchise.playoffRound || 1;

const roundNames = {1:“WILD CARD”,2:“DIVISIONAL”,3:“CONF. CHAMPIONSHIP”,4:“VFL BOWL”};
const roundDesc  = {1:“Top 2 seeds get a bye”,2:“Division champions host”,3:“Conference finals”,4:“Championship game”};

// Build seeded playoff field from leagueRecords (top 7 teams)
const leagueRecords = franchise.leagueRecords || {};
const allTeams = getDraftOrder(leagueRecords); // worst→best
const playoffTeams = […allTeams].reverse().slice(0, 7); // best 7

// Map team ids to display info
function teamInfo(id) {
if (id === “user”) return { city: franchise.city, name: franchise.teamName, primary: pc, secondary: sc, isUser: true };
const meta = VFL_ALL_TEAMS.find(t=>t.id===id) || { city:“VFL”, name:“Team”, primary:”#374151”, secondary:”#9CA3AF” };
return { …meta, isUser: false };
}

// NFL seeding: 1 seed gets bye, plays winner of 4v5 or 3v6 or 2v7 in divisional
// Seeds: 1(bye), 2(bye) vs 7, 3 vs 6, 4 vs 5 — 7-team format
const seeds = playoffTeams.map((t,i) => ({
…t, seed: i+1,
info: teamInfo(t.id),
record: `${t.w||0}-${t.l||0}`,
}));

// Find user seed
const userSeed = seeds.find(s=>s.id===“user”)?.seed || null;
const userInPlayoffs = !!userSeed;

// Wild card matchups: 2v7, 3v6, 4v5 — seed 1 has bye
const wcMatchups = [
{ home: seeds[1], away: seeds[6], id:“wc1” }, // 2 vs 7
{ home: seeds[2], away: seeds[5], id:“wc2” }, // 3 vs 6
{ home: seeds[3], away: seeds[4], id:“wc3” }, // 4 vs 5
].filter(m => m.home && m.away);

// Determine user’s current opponent based on round
function getUserOpponent() {
if (!userSeed) return null;
if (round === 1) {
if (userSeed === 1) return null; // bye
const matchup = wcMatchups.find(m => m.home?.id===“user” || m.away?.id===“user”);
return matchup ? (matchup.home.id===“user” ? matchup.away : matchup.home) : null;
}
// For later rounds, use stored opponent or pick next best remaining
if (franchise.playoffOpponent) return teamInfo(franchise.playoffOpponent);
// Simulate a plausible opponent
const oppSeed = round===2 ? (userSeed===1?7:1) : round===3 ? 2 : 1;
return seeds[Math.min(oppSeed-1, seeds.length-1)]?.info || teamInfo(“t0”);
}

const opp = getUserOpponent();
const hasBye = round === 1 && userSeed === 1;

// Win probability: based on seed difference + team quality
function calcWinProb() {
if (!userSeed) return 0.5;
const oppSeed = round===1 ? (userSeed<=4 ? 9-userSeed : userSeed) : Math.max(1, userSeed-1);
const seedAdv = (oppSeed - userSeed) / 7; // higher seed = better
const winPct = (franchise.wins||0) / Math.max(1, (franchise.wins||0)+(franchise.losses||0));
return Math.min(0.80, Math.max(0.20, 0.48 + seedAdv*0.20 + (winPct-0.5)*0.15));
}

function simRound() {
const prob = calcWinProb();
const win = Math.random() < prob;
setResult(win);
if (win && round >= 4) {
const newLegacy = […(franchise.legacySeasons||[]), {
year:franchise.season, wins:franchise.wins, losses:franchise.losses,
teamName:franchise.name, champion:true, playoffs:true
}];
onUpdate({…franchise, phase:“offseason”, playoffRound:1,
legacySeasons:newLegacy, championships:(franchise.championships||0)+1,
lastChampionId:“user”});
} else if (win) {
setResult(null);
onUpdate({…franchise, playoffRound:round+1});
}
}

function advanceFromBye() {
setResult(null);
onUpdate({…franchise, playoffRound:2});
}

function eliminated() {
const newLegacy = […(franchise.legacySeasons||[]), {
year:franchise.season, wins:franchise.wins, losses:franchise.losses,
teamName:franchise.name, champion:false, playoffs:true
}];
onUpdate({…franchise, phase:“offseason”, playoffRound:1, legacySeasons:newLegacy});
}

