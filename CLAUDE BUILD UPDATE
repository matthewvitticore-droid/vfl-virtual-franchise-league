default: break;
}
});
// Clamp all to 40–99
Object.keys(attrs).forEach(k => {
if (typeof attrs[k] === “number”) attrs[k] = Math.max(40, Math.min(99, attrs[k]));
});
return { …player, attributes: attrs };
}
function clampSpeedByPosition(player) {
