// Scheme fit score: how well a player’s archetype matches the current scheme
// Returns 0.85–1.25 multiplier
function schemeFit(player, offScheme, defScheme) {
const arch = player.archetypeTrait||””;
const pos  = player.position;
const scheme = offScheme||“balanced”;
const dScheme= defScheme||“base43”;
let mult = 1.0;

// OFFENSIVE fits
if(scheme===“runHeavy”) {
if([“Power Back”,“Workhorse”].includes(arch)&&pos===“RB”)  mult=1.20;
if([“Pass Protector”,“Run Blocker”].includes(arch)&&[“LT”,“LG”,“C”,“RG”,“RT”].includes(pos)) mult=1.15;
if([“Elusive”,“Receiving Back”].includes(arch)&&pos===“RB”) mult=0.90; // not ideal
if([“Deep Threat”,“Route Runner”].includes(arch)&&pos===“WR”) mult=0.88;
}
if(scheme===“passHeavy”) {
if([“Deep Threat”,“Route Runner”,“Clutch”].includes(arch)&&pos===“WR”) mult=1.20;
if([“Field General”,“Gunslinger”].includes(arch)&&pos===“QB”)          mult=1.18;
if([“Power Back”,“Workhorse”].includes(arch)&&pos===“RB”)              mult=0.88;
}
if(scheme===“noHuddle”) {
if([“Slot Specialist”,“Route Runner”,“Elusive”].some(a=>arch.includes(a))&&[“WR”,“RB”].includes(pos)) mult=1.22;
if([“Receiving Back”].includes(arch)&&pos===“RB”)    mult=1.25; // 3rd-down backs feast
if([“Game Manager”,“Scrambler”].includes(arch)&&pos===“QB”) mult=1.12;
if([“Power Back”,“Workhorse”].includes(arch)&&pos===“RB”) mult=0.82; // bad fit
if([“Gunslinger”,“Field General”].includes(arch)&&pos===“QB”) mult=1.15;
}

// DEFENSIVE fits
if(dScheme===“threeFour”) {
if([“Pass Rusher”,“Speed Rusher”].includes(arch)&&[“LOLB”,“ROLB”].includes(pos)) mult*=1.20;
if([“Run Stopper”,“Two-Gap”].includes(arch)&&pos===“DT”) mult*=1.15;
}
if(dScheme===“coverTwo”) {
if([“Zone Specialist”,“Ball Hawk”].includes(arch)&&pos===“CB”) mult*=1.15;
if([“Deep Safety”,“Box Safety”].includes(arch)&&pos===“S”)     mult*=1.12;
if([“Press Corner”,“Man Coverage”].includes(arch)&&pos===“CB”) mult*=0.88;
}
if(dScheme===“pressMan”) {
if([“Press Corner”,“Man Coverage”].includes(arch)&&pos===“CB”) mult*=1.22;
if([“Ball Hawk”].includes(arch)&&pos===“S”)   mult*=1.12;
if([“Zone Specialist”].includes(arch)&&pos===“CB”) mult*=0.85;
}
if(dScheme===“base43”) {
if([“Run Stopper”,“Two-Gap”].includes(arch)&&pos===“DT”) mult*=1.12;
if([“Tackler”,“Field General”].includes(arch)&&pos===“MLB”) mult*=1.10;
}

return Math.min(1.30, Math.max(0.80, mult));
}

// ─── SHARED GAME SIMULATION ENGINE ────────────────────────────────────────────
// Rating-driven. Team-first. Every stat flows from actual player attributes.
function simOneGame(roster, offScheme, defScheme) {
offScheme = offScheme||“balanced”;
defScheme = defScheme||“base43”;

const byPos = (pos) => roster.filter(p=>Array.isArray(pos)?pos.includes(p.position):p.position===pos).sort((a,b)=>b.overall-a.overall);

const QB1 = byPos(“QB”)[0]||{id:“qb0”,name:“QB”,overall:72,attributes:{},archetypeTrait:””};
const RBs = byPos(“RB”); const RB1=RBs[0]||{id:“rb0”,name:“RB”,overall:70,attributes:{},archetypeTrait:””}; const RB2=RBs[1];
const WRs = byPos(“WR”); const WR1=WRs[0]; const WR2=WRs[1]; const WR3=WRs[2];
const TE1 = byPos(“TE”)[0];
const OLs = byPos([“LT”,“LG”,“C”,“RG”,“RT”]);
const LBs = byPos([“LOLB”,“MLB”,“ROLB”]);
const CBs = byPos(“CB”); const Ss=byPos(“S”); const DEs=byPos([“RE”,“LE”]); const DTs=byPos(“DT”);

// ── RATING HELPERS ──
const attr  = (p,k,fb) => (p?.attributes?.[k]||p?.overall*0.88||fb||70);
const norm  = (p,k,fb) => attr(p,k,fb)/99;
const fit   = (p)      => schemeFit(p, offScheme, defScheme);

// Key ratings — using new attribute system
const qbAcc = norm(QB1,“THA”,72);           // throw accuracy
