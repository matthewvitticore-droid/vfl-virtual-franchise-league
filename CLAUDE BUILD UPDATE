// Hard floors — enforce AFTER all calculation
// These CANNOT be violated regardless of overall, dev trait, or randomness
function enforceHardFloors(attrs, combine) {
if(!combine) return attrs;
const forty = parseFloat(combine.fortyYard||9);
const cone  = parseFloat(combine.threeCone||9);
const shut  = parseFloat(combine.shuttle||9);
const out   = {…attrs};
// Speed floors — mapped directly to 40 time
if(forty<=4.28)      { if((out.SPD||0)<98) out.SPD=98+ri(0,1); }
else if(forty<=4.32) { if((out.SPD||0)<96) out.SPD=96+ri(0,2); }
else if(forty<=4.36) { if((out.SPD||0)<93) out.SPD=93+ri(0,3); }
else if(forty<=4.40) { if((out.SPD||0)<90) out.SPD=90+ri(0,3); }
else if(forty<=4.45) { if((out.SPD||0)<87) out.SPD=87+ri(0,3); }
else if(forty<=4.50) { if((out.SPD||0)<84) out.SPD=84+ri(0,3); }
// Acceleration floors — 3 cone maps to ACC
if(cone<=6.50)       { if((out.ACC||0)<96) out.ACC=96+ri(0,2); }
else if(cone<=6.60)  { if((out.ACC||0)<93) out.ACC=93+ri(0,3); }
else if(cone<=6.70)  { if((out.ACC||0)<90) out.ACC=90+ri(0,3); }
else if(cone<=6.80)  { if((out.ACC||0)<87) out.ACC=87+ri(0,3); }
else if(cone<=6.90)  { if((out.ACC||0)<84) out.ACC=84+ri(0,3); }
// Agility floors — shuttle maps to AGI
if(shut<=4.10)       { if((out.AGI||0)<94) out.AGI=94+ri(0,2); }
else if(shut<=4.15)  { if((out.AGI||0)<90) out.AGI=90+ri(0,3); }
else if(shut<=4.20)  { if((out.AGI||0)<86) out.AGI=86+ri(0,3); }
// Cap at 99
Object.keys(out).forEach(k=>{ if(typeof out[k]===“number”) out[k]=Math.min(99,out[k]); });
return out;
}

