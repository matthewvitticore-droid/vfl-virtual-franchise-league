const attrs = { …(player.attributes || {}) };
if (attrs.SPD == null) return player;
const pos = player.position;
const group = getGroup(pos);
const ranges = {
QB:[65,85], RB:[82,96], WR:[85,97], TE:[70,88],
OL:[50,70], DL:[60,80], LB:[70,88], CB:[88,97],
S:[82,95],  K:[40,60],  P:[40,60],
