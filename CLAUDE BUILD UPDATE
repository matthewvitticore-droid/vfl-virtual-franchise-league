const FORTY_SPD  = [[4.20,99],[4.25,98],[4.29,97],[4.33,95],[4.37,93],[4.41,90],[4.45,88],[4.50,85],[4.55,82],[4.60,78],[4.65,74],[4.70,70],[4.80,63],[5.00,55]];
